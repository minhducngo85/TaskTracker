version: '3.8'

services:

  backend:
    build: ./TaskTracker
    container_name: tasktracker-backend
    ports:
      - "8080:8080"
    restart: always

  frontend:
    build: ./TaskTrackerFrontend
    container_name: tasktracker-frontend
    ports:
      - "80:80"
    depends_on:
      - backend
    restart: always